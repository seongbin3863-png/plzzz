# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# VITE_KAKAO_MAP_API_KEY: 카카오 지도를 표시하기 위해 발급받은 카카오 Javascript API 키입니다.
# (키 없이도 서비스가 정상적으로 작동하며, 환경 변수 입력 시 실시간 카카오 지도로 업그레이드됩니다.)
VITE_KAKAO_MAP_API_KEY=""

# VITE_REPORT_EMAIL: 응원 스팟 제보를 받을 운영자 이메일
# formsubmit.co를 사용 — 계정 가입 불필요
# 1. 이메일 주소만 입력하면 됨
# 2. 첫 제보 수신 시 formsubmit.co에서 활성화 메일이 발송됨
# 3. 활성화 메일의 버튼 클릭 후 이후 모든 제보가 정상 수신됨
VITE_REPORT_EMAIL=""

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# VITE_KAKAO_MAP_API_KEY: 카카오 지도를 표시하기 위해 발급받은 카카오 Javascript API 키입니다.
# (키 없이도 서비스가 정상적으로 작동하며, 환경 변수 입력 시 실시간 카카오 지도로 업그레이드됩니다.)
VITE_KAKAO_MAP_API_KEY=""

# VITE_FORMSPREE_ENDPOINT: 응원 스팟 제보를 운영자 이메일로 전송합니다.
# 1. https://formspree.io 에서 회원가입 (Gmail 사용 가능)
# 2. New Form 생성 → 이메일 설정
# 3. Form Endpoint 복사 (예: https://formspree.io/f/xyzabcde)
VITE_FORMSPREE_ENDPOINT=""
